# Wajib
HELIUS_API_KEY=your_helius_key
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_WEBHOOK_SECRET=random_secret_string

# Opsional: untuk fetch metrik pool (historical price/volume)
BIRDEYE_API_KEY=your_birdeye_key

# Mode
DRY_RUN=true
LOG_LEVEL=info
VERBOSE=false

# Port untuk webhook receiver + dashboard
WEBHOOK_PORT=3001

# Opsional: Telegram bot notifikasi + query commands
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_USER_IDS=
