# Wajib
# Bisa satu key, atau multiple keys (dipakai bergantian untuk menghindari rate-limit):
# HELIUS_API_KEY=key1,key2,key3
# atau HELIUS_API_KEY_1=... HELIUS_API_KEY_2=...
HELIUS_API_KEY=your_helius_key
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_WEBHOOK_SECRET=random_secret_string

# Opsional: mix dengan public pump.helius-rpc.com untuk generic RPC reads
# HELIUS_PUMP_RPC_URL=https://pump.helius-rpc.com
# HELIUS_USE_PUMP_FOR_RPC=true    # set true untuk coba pump dulu, fallback ke HELIUS_RPC_URL

# Opsional: tuning key manager (cooldown setelah 429/gagal)
# RATE_LIMIT_COOLDOWN_MS=60000
# FAILURE_COOLDOWN_MS=30000
# MAX_FAILURES_PER_KEY=5

# Opsional: Meteora Pool Discovery API rate limiting (untuk mengurangi 429)
# METEORA_POOL_MAX_IN_FLIGHT=2
# METEORA_POOL_DISPATCH_DELAY_MS=250
# METEORA_POOL_CIRCUIT_FAILURE_THRESHOLD=5
# METEORA_POOL_CIRCUIT_OPEN_MS=60000

# Opsional: untuk fetch metrik pool (historical price/volume)
BIRDEYE_API_KEY=your_birdeye_key

# Opsional: GMGN API key. Kalau tidak diisi, Scout akan coba gmgn-cli dulu,
# lalu DexScreener sebagai fallback terakhir untuk buy/sell trade flow.
GMGN_API_KEY=

# Agent Meridian rate/concurrency tuning (lower = fewer 500s upstream)
AGENT_MERIDIAN_MAX_IN_FLIGHT=2
AGENT_MERIDIAN_DISPATCH_DELAY_MS=150

# Birdeye rate limiting (public tier is aggressively capped)
BIRDEYE_MAX_IN_FLIGHT=1
BIRDEYE_DISPATCH_DELAY_MS=300

# GMGN HTTP API rate limiting (jika GMGN_API_KEY digunakan)
GMGN_MAX_IN_FLIGHT=3
GMGN_DISPATCH_DELAY_MS=150

# gmgn-cli subprocess rate limiting (jika GMGN_API_KEY tidak diisi tapi CLI terinstall)
GMGN_CLI_MAX_IN_FLIGHT=2
GMGN_CLI_DISPATCH_DELAY_MS=250

# DexScreener free fallback rate limiting (no API key)
DEXSCREENER_MAX_IN_FLIGHT=3
DEXSCREENER_DISPATCH_DELAY_MS=150

# Mode
DRY_RUN=true
LOG_LEVEL=info
VERBOSE=false

# Webhook receiver port (Helius posts here)
WEBHOOK_PORT=3001

# Dashboard port (separate, easier LAN access)
DASHBOARD_PORT=8080

# Cloudflare Tunnel (optional)
# Leave empty for a random *.trycloudflare.com quick tunnel.
# Set to a named tunnel token for a stable public URL.
CLOUDFLARE_TUNNEL_TOKEN=

# Opsional: Telegram bot notifikasi + query commands
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_USER_IDS=
